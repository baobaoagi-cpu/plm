# Offline-safe defaults. Phase 3C must keep all external integrations disabled.
APP_ENV=development
LOG_LEVEL=INFO
EXTERNAL_PROVIDERS_ENABLED=false
LINE_INTEGRATION_ENABLED=false
LIFF_IDENTITY_ENABLED=false
DATABASE_ENABLED=false
ADMIN_DATABASE_ENABLED=false
ADMIN_HTTP_ENABLED=false
LIVEKIT_ENABLED=false

# Owner-calibration safety controls.
XIEWENXIAN_CALIBRATION_ENABLED=false
XIEWENXIAN_CALIBRATION_KILL_SWITCH=true
XIEWENXIAN_CALIBRATION_SANDBOX_MODE=true
XIEWENXIAN_CALIBRATION_LINE_ALLOWLIST_JSON=

# LINE / LIFF server slots. Never expose secrets through VITE_*.
XIEWENXIAN_CALIBRATION_LINE_CHANNEL_ID=
XIEWENXIAN_CALIBRATION_LINE_ISSUER=https://access.line.me
XIEWENXIAN_CALIBRATION_LINE_CHANNEL_SECRET=
XIEWENXIAN_CALIBRATION_LINE_CHANNEL_ACCESS_TOKEN=
XIEWENXIAN_CALIBRATION_LIFF_ID=
XIEWENXIAN_CALL_GRANT_SIGNING_KEY=
VITE_LIFF_ID=
VITE_LIFF_IDENTITY_ENABLED=false
VITE_WS_URL=

# Provider slots. Provider selection and real calls require a later human gate.
MINIMAX_API_KEY=
MINIMAX_MODEL=
XIEWENXIAN_CALIBRATION_MINIMAX_VOICE_ID=
# Historical Task 002 spike only; the 3.0 runtime uses the persona-scoped slot above.
MINIMAX_VOICE_ID=
MINIMAX_OUTPUT_FORMAT=mp3
MINIMAX_SAMPLE_RATE=24000
MINIMAX_CHANNELS=1
XIEWENXIAN_STT_PROVIDER=
XIEWENXIAN_STT_API_KEY=
XIEWENXIAN_STT_MODEL=
XIEWENXIAN_STT_LANGUAGE=zh-TW
XIEWENXIAN_LLM_PROVIDER=
XIEWENXIAN_LLM_API_KEY=
XIEWENXIAN_LLM_MODEL=

# Isolated staging database slots. No database is contacted by Phase 3C.
XIEWENXIAN_STAGING_DATABASE_URL=
XIEWENXIAN_STAGING_ADMIN_READONLY_DATABASE_URL=
XIEWENXIAN_STAGING_DB_SCHEMA=xiewenxian_staging
XIEWENXIAN_ADMIN_SESSION_SECRET=

# Optional later WebRTC transport. LiveKit Agents remain forbidden.
XIEWENXIAN_CALIBRATION_LIVEKIT_URL=
XIEWENXIAN_CALIBRATION_LIVEKIT_API_KEY=
XIEWENXIAN_CALIBRATION_LIVEKIT_API_SECRET=

# Full-duplex media contract.
VOICE_INPUT_SAMPLE_RATE=16000
VOICE_INPUT_CHANNELS=1
VOICE_INPUT_SAMPLE_WIDTH_BYTES=2
VOICE_INPUT_ENCODING=pcm_s16le
VOICE_INPUT_FRAME_MS=20
TTS_SESSION_STRATEGY=one_session_per_generation
GENERATION_GUARD_ENABLED=true
STALE_GENERATION_POLICY=discard
ENABLE_INTERRUPTION=true
MIN_OVERLAP_MS=180
INTERRUPTION_CONFIRMATION_MS=300
TTS_MAX_PENDING_AUDIO_MS=2000
CALL_INPUT_QUEUE_MAX_MS=1000
CALL_WS_MAX_FRAME_BYTES=65536
TEXT_CHUNK_MIN_CHARS=6
TEXT_CHUNK_PREFERRED_CHARS=16
TEXT_CHUNK_MAX_CHARS=32
TEXT_CHUNK_MAX_WAIT_MS=250
ENABLE_DEBUG_EVENTS=true
ENABLE_AUDIO_DUMP=false
